# HomeBase — Environment Variables
# Copy this file to .env and fill in your real values.
# The .env file is git-ignored so secrets are never committed.

# --- LLM Routing (required for router="llm" mode) ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Google OAuth 2.0 (required for real Calendar/Gmail/Tasks) ---
# Option 1: Set these directly (or)
# Option 2: Place a credentials.json file in the project root (downloaded from Google Cloud Console)
GOOGLE_CLIENT_ID=your-oauth-client-id
GOOGLE_CLIENT_SECRET=your-oauth-client-secret

# --- Mock mode ---
# Set to 1 to use mock data instead of real APIs (for demos/testing)
# HOMEBASE_MOCK=1
